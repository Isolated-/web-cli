{
  "name": "web-cli",
  "description": "A new CLI generated with oclif",
  "version": "0.1.0",
  "author": "Michael Palmer",
  "bin": {
    "web": "./bin/run.js"
  },
  "bugs": "https://github.com/crawler/data-cli/issues",
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-plugins": "^5",
    "@types/cli-progress": "^3.11.6",
    "@xgsd/artifact-sdk": "../artifact-sdk",
    "@xgsd/registry-sdk": "../../registry-sdk",
    "axios": "^1.17.0",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "joi": "^18.2.1",
    "keytar": "^7.9.0",
    "moment": "^2.30.1",
    "ms": "^2.1.3",
    "ora": "^9.4.0",
    "pretty-bytes": "^7.1.0",
    "pretty-ms": "^9.3.0",
    "tar": "^7.5.16",
    "treeify": "^1.1.0",
    "yaml": "^2.9.0",
    "yml": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^1",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/chai": "^4",
    "@types/mocha": "^10",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/treeify": "^1.0.3",
    "chai": "^4",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "mocha": "^11",
    "oclif": "^4",
    "shx": "^0.3.3",
    "ts-node": "^10",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/crawler/data-cli",
  "keywords": [
    "oclif"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "web",
    "dirname": "web-cli",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help"
    ],
    "topicSeparator": " ",
    "topics": {}
  },
  "repository": "crawler/data-cli",
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "yarn lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md"
  },
  "types": "dist/index.d.ts"
}
